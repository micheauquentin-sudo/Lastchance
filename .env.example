# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_HOSTS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Clé séparée recommandée pour le site d'administration.
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

# Secrets applicatifs — générer des valeurs aléatoires indépendantes.
PLAYER_KEY_SALT=
SPIN_TOKEN_SECRET=
CLAIM_TOKEN_SECRET=
TEAM_INVITE_TOKEN_SECRET=
UNSUBSCRIBE_TOKEN_SECRET=
# Anciennes clés acceptées pendant une rotation, séparées par des virgules.
CLAIM_TOKEN_SECRET_PREVIOUS=
TEAM_INVITE_TOKEN_SECRET_PREVIOUS=
UNSUBSCRIBE_TOKEN_SECRET_PREVIOUS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_STARTER=
STRIPE_WEBHOOK_SECRET=

# Emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Protection anti-bot (obligatoire par défaut en production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Vide : facultatif en local, obligatoire implicitement en production.
TURNSTILE_REQUIRED=
TURNSTILE_ALLOWED_HOSTS=
TRUSTED_PROXY_PROVIDER=

# Rate limiting distribué (optionnel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics avec consentement (optionnel)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (optionnel)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SLOW_OPERATION_THRESHOLD_MS=1000

# Tâches planifiées et sessions admin
CRON_SECRET=
ADMIN_SESSION_MAX_MINUTES=480
ADMIN_SUDO_MINUTES=15

# Google Wallet (optionnel)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLIENT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=

# Mentions légales
LEGAL_ENTITY_NAME=
